<Application x:Class="S7WpfApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:S7WpfApp.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ═══════════════ 浅色工业风配色（ISA-101） ═══════════════ -->
            <Color x:Key="PageBg">#F0F2F5</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="SurfaceBg">#E8EAED</Color>
            <Color x:Key="Accent">#00796B</Color>          <!-- Teal 深邃蓝绿 -->
            <Color x:Key="Danger">#D32F2F</Color>          <!-- 报警红（仅异常） -->
            <Color x:Key="Warning">#FF9800</Color>          <!-- 警告橙 -->
            <Color x:Key="Success">#4CAF50</Color>          <!-- 运行绿 -->
            <Color x:Key="Inactive">#9E9E9E</Color>        <!-- 未激活灰 -->
            <Color x:Key="TextPrimary">#333333</Color>      <!-- 炭黑文字 -->
            <Color x:Key="TextSecondary">#757575</Color>    <!-- 次要文字 -->
            <Color x:Key="Border">#D0D0D0</Color>
            <Color x:Key="InputBg">#FAFAFA</Color>
            <Color x:Key="HoverBg">#E0E0E0</Color>

            <SolidColorBrush x:Key="PageBgBrush" Color="{StaticResource PageBg}"/>
            <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceBg}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
            <SolidColorBrush x:Key="InactiveBrush" Color="{StaticResource Inactive}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
            <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBg}"/>
            <SolidColorBrush x:Key="HoverBgBrush" Color="{StaticResource HoverBg}"/>

            <!-- 兼容旧名称 -->
            <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PageBg}"/>
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource SurfaceBg}"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Danger}"/>

            <!-- 转换器 -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <converters:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
            <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter"/>
            <converters:BindingTypeToColorConverter x:Key="TypeToColorConverter"/>
            <converters:BindingTypeToIconConverter x:Key="TypeToIconConverter"/>
            <converters:BoolToStatusColorConverter x:Key="BoolToStatusColorConverter"/>

            <!-- ═══════════════ 按钮样式 ═══════════════ -->
            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="14,7"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverBgBrush}"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#C8E6C9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════ TextBox ═══════════════ -->
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="CaretBrush" Value="#00796B"/>
                <Setter Property="SelectionBrush" Value="#4000796B"/>
            </Style>

            <!-- ═══════════════ TabItem ═══════════════ -->
            <Style TargetType="TabItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="Padding" Value="18,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    BorderBrush="Transparent" BorderThickness="0,0,0,3"
                                    Margin="0,0,2,0">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource CardBgBrush}"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#E0F2F1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════ ComboBox ═══════════════ -->
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Padding" Value="10,8"/>
                <Style.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter Property="Background" Value="#E0F2F1"/>
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ═══════════════ ListView / ListViewItem ═══════════════ -->
            <Style TargetType="ListViewItem">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="4,3"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                      Columns="{TemplateBinding GridView.ColumnCollection}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E8F5E9"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E0F2F1"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#B2DFDB"/>
                                    <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,1"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="#E0F2F1"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- GridView 表头 -->
            <Style TargetType="GridViewColumnHeader">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="Padding" Value="10,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <!-- ═══════════════ CheckBox ═══════════════ -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>

            <!-- ═══════════════ ScrollBar ═══════════════ -->
            <Style TargetType="ScrollViewer">
                <Setter Property="Background" Value="Transparent"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
