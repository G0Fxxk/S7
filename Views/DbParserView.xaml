<UserControl x:Class="S7WpfApp.Views.DbParserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 工具栏 ═══ -->
        <Border Grid.Row="0" Background="{StaticResource CardBgBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="16,10" Margin="0,0,0,10">
            <WrapPanel VerticalAlignment="Center">
                <Button Content="📂 导入 DB 文件" Click="OnImportClick" Margin="0,0,8,0"/>
                <Button Content="📖 全部读取" Click="OnReadAllClick" Margin="0,0,8,0"/>
                <Button Content="▶ 自动刷新" Click="OnAutoRefreshClick" Margin="0,0,8,0"/>
                <Button Content="✅ 全选" Click="OnSelectAllClick" Margin="0,0,8,0"/>
                <Button Content="⬜ 取消全选" Click="OnDeselectAllClick" Margin="0,0,8,0"/>
                <Button Content="📈 趋势" Click="OnTrendClick" Margin="0,0,8,0"/>
                <Button Content="⭐ 符号" Click="OnAddSymbolClick" Margin="0,0,8,0"/>
                <Button Content="📋 管理" Click="OnManageSymbolsClick"/>
            </WrapPanel>
        </Border>

        <!-- ═══ DB 信息 ═══ -->
        <Border Grid.Row="1" Background="{StaticResource CardBgBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="16,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DbInfoText" Text="等待导入 DB 文件..."
                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="写入值:" Foreground="{StaticResource TextSecondaryBrush}" 
                               VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                    <TextBox x:Name="WriteValueBox" Width="120" Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <Button Content="✏️ 写入" Click="OnWriteClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 变量列表 ═══ -->
        <Border Grid.Row="2" Background="{StaticResource CardBgBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="4">
            <ListView x:Name="VariablesList" Background="Transparent" BorderThickness="0"
                      SelectionChanged="OnVariableSelected" Foreground="{StaticResource TextPrimaryBrush}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="" Width="56">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsSelected}" Click="OnCheckboxClick" VerticalAlignment="Center"/>
                                        <!-- 数组展开/折叠图标 -->
                                        <TextBlock Text="{Binding ExpandIcon}" FontSize="10" Margin="4,0,0,0"
                                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                                   Cursor="Hand" MouseLeftButtonDown="OnExpandIconClick" Tag="{Binding}"
                                                   Visibility="{Binding IsArrayParent, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="变量名" Width="240">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="{Binding IsArrayParent, Converter={StaticResource BoolToFontWeightConverter}}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="数据类型" Width="90" DisplayMemberBinding="{Binding DataType}"/>
                        <GridViewColumn Header="偏移地址" Width="120" DisplayMemberBinding="{Binding Address}"/>
                        <GridViewColumn Header="当前值" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CurrentValue, FallbackValue='--'}" 
                                               Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="符号名" Width="150" DisplayMemberBinding="{Binding BoundSymbolName}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- ═══ 状态栏 ═══ -->
        <Border Grid.Row="3" Background="{StaticResource CardBgBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="16,8" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" Text="就绪" 
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
