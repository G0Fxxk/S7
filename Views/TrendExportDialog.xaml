<Window x:Class="S7WpfApp.Views.TrendExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="趋势数据导出设置" Height="420" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="4,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 时间选择 -->
        <GroupBox Grid.Row="0" Header="📅 时间范围" Foreground="#00C8FF" BorderBrush="#444" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <CheckBox x:Name="UseTimeRangeCheck" Content="指定时间范围（不勾选则导出全部数据）" IsChecked="False"
                          Checked="OnTimeRangeCheckChanged" Unchecked="OnTimeRangeCheckChanged"/>
                <Grid Margin="0,6,0,0" x:Name="TimeRangePanel" IsEnabled="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="起始:" Grid.Column="0"/>
                    <TextBox x:Name="StartTimeBox" Grid.Column="1" Background="#2D2D2D" Foreground="#E0E0E0"
                             Margin="4,0" Padding="4,3" FontSize="12"/>
                    <TextBlock Text="结束:" Grid.Column="2"/>
                    <TextBox x:Name="EndTimeBox" Grid.Column="3" Background="#2D2D2D" Foreground="#E0E0E0"
                             Margin="4,0" Padding="4,3" FontSize="12"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- 通道筛选 -->
        <GroupBox Grid.Row="1" Header="📊 通道筛选" Foreground="#00C8FF" BorderBrush="#444" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <CheckBox x:Name="SelectAllCheck" Content="全选 / 取消全选" IsChecked="True"
                          Checked="OnSelectAllChanged" Unchecked="OnSelectAllChanged"/>
            </StackPanel>
        </GroupBox>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <ItemsControl x:Name="ChannelCheckList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsExportSelected, Mode=TwoWay}"
                                  Foreground="#E0E0E0" Margin="24,2,0,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 导出选项 -->
        <GroupBox Grid.Row="3" Header="⚙ 导出选项" Foreground="#00C8FF" BorderBrush="#444" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <CheckBox x:Name="IncludeChartCheck" Content="包含趋势图截图" IsChecked="True"/>
                <CheckBox x:Name="IncludeDataCheck" Content="包含采样数据表格" IsChecked="True"/>
            </StackPanel>
        </GroupBox>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取 消" Background="#555" Click="OnCancelClick" Margin="0,0,10,0"/>
            <Button Content="导出 PDF" Click="OnExportPdfClick" Margin="0,0,10,0"/>
            <Button Content="导出 CSV" Click="OnExportCsvClick"/>
        </StackPanel>
    </Grid>
</Window>
