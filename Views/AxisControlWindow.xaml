<Window x:Class="S7WpfApp.Views.AxisControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="轴控制" Height="620" Width="520"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF" CornerRadius="10" Padding="18,14"
                BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="AxisNameText" Text="轴名称" FontSize="18" FontWeight="Bold" Foreground="#00796B"/>
                    <TextBlock x:Name="AxisIdText" Text="" FontSize="10" Foreground="#757575"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="当前位置" FontSize="17" Foreground="#757575" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PositionText" Text="0.000" FontSize="28" FontWeight="Bold"
                               Foreground="#333333" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="10" Padding="14,10"
                BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel x:Name="NegLimitPanel" Orientation="Horizontal" Margin="0,0,20,0">
                    <Ellipse x:Name="NegLimitDot" Width="10" Height="10" Fill="#9E9E9E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="负限位" Foreground="#757575" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Ellipse x:Name="OriginDot" Width="10" Height="10" Fill="#9E9E9E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="原点" Foreground="#757575" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel x:Name="PosLimitPanel" Orientation="Horizontal">
                    <Ellipse x:Name="PosLimitDot" Width="10" Height="10" Fill="#9E9E9E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="正限位" Foreground="#757575" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#FFFFFF" CornerRadius="10" Padding="18,14"
                BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="点动控制" FontSize="14" FontWeight="SemiBold" Foreground="#00796B" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="BackwardBtn" Background="#E8EAED" CornerRadius="6" Padding="0,12" Cursor="Hand"
                            MouseLeftButtonDown="OnBackwardDown" MouseLeftButtonUp="OnBackwardUp">
                        <TextBlock Text="后退" Foreground="#333333" HorizontalAlignment="Center" FontSize="13"/>
                    </Border>
                    <Border Grid.Column="2" x:Name="ForwardBtn" Background="#E8EAED" CornerRadius="6" Padding="0,12" Cursor="Hand"
                            MouseLeftButtonDown="OnForwardDown" MouseLeftButtonUp="OnForwardUp">
                        <TextBlock Text="前进" Foreground="#333333" HorizontalAlignment="Center" FontSize="13"/>
                    </Border>
                </Grid>
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="点动速度" Foreground="#757575" FontSize="11" Margin="0,0,0,2"/>
                    <TextBox x:Name="JogSpeedBox" Text="0" FontSize="14" FontWeight="SemiBold"
                             GotFocus="OnValueBoxFocus" LostFocus="OnValueBoxLostFocus"
                             KeyDown="OnValueBoxKeyDown" Tag="JogSpeed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="#FFFFFF" CornerRadius="10" Padding="18,14"
                BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="EnableBtn" Content="使能" Padding="0,12" Click="OnEnableClick"/>
                <Button Grid.Column="2" Content="回原位" Padding="0,12" Click="OnHomeClick"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#FFFFFF" CornerRadius="10" Padding="18,14"
                BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="手动定位" FontSize="14" FontWeight="SemiBold" Foreground="#00796B" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="目标位置" Foreground="#757575" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="TargetPosBox" Text="0" FontSize="14"
                                 GotFocus="OnValueBoxFocus" LostFocus="OnValueBoxLostFocus"
                                 KeyDown="OnValueBoxKeyDown" Tag="TargetPos"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="定位速度" Foreground="#757575" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="MoveSpeedBox" Text="100" FontSize="14"
                                 GotFocus="OnValueBoxFocus" LostFocus="OnValueBoxLostFocus"
                                 KeyDown="OnValueBoxKeyDown" Tag="MoveSpeed"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="执行" PreviewMouseDown="OnManualMoveDown"
                            Padding="16,0" VerticalAlignment="Top" Height="38" Margin="0,10,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#00796B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
