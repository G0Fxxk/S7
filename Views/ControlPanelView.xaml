<UserControl x:Class="S7WpfApp.Views.ControlPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 工具栏 ═══ -->
        <Border Grid.Row="0" Background="{StaticResource CardBgBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="16,10" Margin="0,0,0,10">
            <WrapPanel>
                <Button Content="➕ 添加控件" Click="OnAddControlClick" Margin="0,0,8,0"/>
                <Button Content="🔧 添加轴控" Click="OnAddAxisClick" Margin="0,0,8,0"/>
                <Button Content="📥 导入配置" Click="OnImportClick" Margin="0,0,8,0"/>
                <Button Content="📤 导出配置" Click="OnExportClick" Margin="0,0,8,0"/>
                <Button Content="📈 趋势监控" Click="OnOpenTrendClick" Margin="0,0,8,0" Padding="12,5"
                        Background="#E3F2FD" BorderBrush="#90CAF9" Foreground="#0D47A1" FontWeight="Bold"/>
            </WrapPanel>
        </Border>

        <!-- ═══ 控件组列表 ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GroupsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Padding="16" Margin="0,0,0,10">
                            <StackPanel>
                                <!-- 组标题 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="📦" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                                        <Run Text="("/>
                                        <Run Text="{Binding Controls.Count, Mode=OneWay}"/>
                                        <Run Text=" 个控件)"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- 卡片网格 -->
                                <ItemsControl ItemsSource="{Binding Controls}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- ═══ 单张 MAUI 风格卡片 ═══ -->
                                            <Border Width="210" Margin="0,0,10,10"
                                                    Background="{StaticResource CardBgBrush}"
                                                    CornerRadius="12"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Loaded="OnCardLoaded" Tag="{Binding}">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                                                      Opacity="0.08" Color="#000000"/>
                                                </Border.Effect>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="6"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- 顶部类型色块 -->
                                                    <Border Grid.Row="0" CornerRadius="12,12,0,0"
                                                            Background="{Binding Binding.Type, Converter={StaticResource TypeToColorConverter}}"/>

                                                    <!-- 卡片内容 -->
                                                    <StackPanel Grid.Row="1" Margin="14,12,14,14">
                                                        <!-- 图标 + 名称 -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                            <TextBlock Text="{Binding Binding.Type, Converter={StaticResource TypeToIconConverter}}"
                                                                       FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Binding.Name}"
                                                                       FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="150" VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <!-- 地址 -->
                                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Margin="0,0,0,2">
                                                            <Run Text="📍 "/>
                                                            <Run Text="{Binding Binding.Address, Mode=OneWay}"/>
                                                        </TextBlock>

                                                        <!-- 类型 + 当前值 -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <TextBlock Text="{Binding Binding.DataType}"
                                                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="{Binding DisplayValue, Mode=OneWay}"
                                                                       FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource AccentBrush}"/>
                                                        </StackPanel>

                                                        <!-- 操作按钮区域（点动/保持/数值/轴控） -->
                                                        <Grid Margin="0,4,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- 操作按钮（状态指示不显示） -->
                                                            <Button x:Name="ActionBtn" Tag="{Binding}"
                                                                    Click="OnControlClick"
                                                                    PreviewMouseDown="OnControlMouseDown"
                                                                    PreviewMouseUp="OnControlMouseUp"
                                                                    Padding="10,6" FontSize="12"
                                                                    HorizontalAlignment="Stretch">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                        <Setter Property="Content" Value="⚡ 操作"/>
                                                                        <Setter Property="Background" Value="#E8EAED"/>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Button Grid.Column="1" Content="🗑️" Tag="{Binding}"
                                                                    Click="OnDeleteControlClick"
                                                                    Padding="8,6" Margin="6,0,0,0" FontSize="12"
                                                                    Visibility="{Binding DataContext.ShellVm.IsAdmin, 
                                                                        RelativeSource={RelativeSource AncestorType=Window},
                                                                        Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
