<UserControl x:Class="S7WpfApp.Views.DbFilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 工具栏 ═══ -->
        <Border Grid.Row="0" Background="{StaticResource CardBgBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="16,10" Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock Text="📁" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="DB 文件管理" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <Button Content="📂 导入文件" Click="OnImportClick" Margin="0,0,8,0"/>
                <Button Content="🔄 刷新列表" Click="OnRefreshClick"/>
            </WrapPanel>
        </Border>

        <!-- ═══ 文件列表 ═══ -->
        <Border Grid.Row="1" Background="{StaticResource CardBgBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4">
            <ListView x:Name="FilesList" Background="Transparent" BorderThickness="0"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      MouseDoubleClick="OnFileDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="DB 编号" Width="80" DisplayMemberBinding="{Binding DbNumber}"/>
                        <GridViewColumn Header="DB 名称" Width="160" DisplayMemberBinding="{Binding DbName}"/>
                        <GridViewColumn Header="文件名" Width="200" DisplayMemberBinding="{Binding FileName}"/>
                        <GridViewColumn Header="变量数" Width="80" DisplayMemberBinding="{Binding VariableCount}"/>
                        <GridViewColumn Header="更新时间" Width="160" 
                                        DisplayMemberBinding="{Binding LastUpdateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                        <GridViewColumn Header="操作" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="🔄 重导入" Tag="{Binding}" Click="OnReimportClick" 
                                                Padding="8,4" Margin="0,0,6,0" FontSize="11"/>
                                        <Button Content="🗑️ 删除" Tag="{Binding}" Click="OnDeleteClick" 
                                                Padding="8,4" FontSize="11">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
