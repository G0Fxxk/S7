<UserControl x:Class="S7WpfApp.Views.ConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBgBrush}">

    <Grid Margin="20" HorizontalAlignment="Left">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Width="400" VerticalAlignment="Top"
                Background="{StaticResource CardBgBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="24" Height="420">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <TextBlock Text="👤" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="用户登录" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>

                <TextBlock Text="用户名" Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="0,0,0,4" FontSize="12"/>
                <TextBox x:Name="UsernameBox" Margin="0,0,0,12"/>

                <TextBlock Text="密码" Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="0,0,0,4" FontSize="12"/>
                <PasswordBox x:Name="PasswordBox" Background="{StaticResource InputBgBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="8,6" Margin="0,0,0,12"/>

                <CheckBox x:Name="RememberCheck" Content="记住密码" Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="LoginBtn" Content="🔑 登录" Click="OnLoginClick" 
                            Margin="0,0,8,0" Padding="20,8" Width="352"/>
                    <Button x:Name="LogoutBtn" Content="🚪 登出" Click="OnLogoutClick"
                            Padding="20,8" Visibility="Collapsed"/>
                </StackPanel>

                <TextBlock x:Name="LoginStatusText" Margin="0,10,0,0" FontSize="12"
                           Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Width="400" VerticalAlignment="Top"
                Background="{StaticResource CardBgBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="24">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <TextBlock Text="⚡" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="PLC 连接配置" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>

                <TextBlock Text="PLC IP 地址" Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="0,0,0,4" FontSize="12"/>
                <TextBox x:Name="IpBox" Text="192.168.1.200" Margin="0,0,0,12"/>

                <TextBlock Text="CPU 类型" Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="0,0,0,4" FontSize="12"/>
                <ComboBox x:Name="CpuTypeCombo" Margin="0,0,0,12">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FAFAFA"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E0F2F1"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#00796B"/>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="S7-200" Tag="0"/>
                    <ComboBoxItem Content="S7-200 Smart" Tag="1"/>
                    <ComboBoxItem Content="S7-300" Tag="10"/>
                    <ComboBoxItem Content="S7-400" Tag="20"/>
                    <ComboBoxItem Content="S7-1200" Tag="30" IsSelected="True"/>
                    <ComboBoxItem Content="S7-1500" Tag="40"/>
                </ComboBox>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Rack" Foreground="{StaticResource TextSecondaryBrush}" 
                                   Margin="0,0,0,4" FontSize="12"/>
                        <TextBox x:Name="RackBox" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Slot" Foreground="{StaticResource TextSecondaryBrush}" 
                                   Margin="0,0,0,4" FontSize="12"/>
                        <TextBox x:Name="SlotBox" Text="1"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="AutoReconnectCheck" Content="自动重连" IsChecked="True"
                          Margin="0,0,0,18" Checked="OnAutoReconnectChanged" 
                          Unchecked="OnAutoReconnectChanged"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="ConnectBtn" Grid.Column="0" Content="🔌 连接"
                            Click="OnConnectClick" Padding="12,10" FontSize="14">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#0a6e3a"/>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="DisconnectBtn" Grid.Column="2" Content="⛔ 断开"
                            Click="OnDisconnectClick" Padding="12,10" FontSize="14" IsEnabled="False">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#6e1a1a"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <Border Background="{StaticResource PageBgBrush}" CornerRadius="8" 
                        Padding="14,10" Margin="0,14,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse x:Name="StatusDot" Width="10" Height="10" 
                                     Fill="#e94560" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ConnectionStatusText" Text="未连接" 
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="LatencyText" Text="延迟: --" 
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

