<Window x:Class="S7WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:S7WpfApp.Views"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title=" S7-plc" 
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 顶栏 ═══ -->
        <Border Grid.Row="0" Background="{StaticResource CardBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text=" PLC 工业控制系统" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Siemens S7 Series Monitor" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- 右侧控件组：连接状态与管理员按钮 -->
                <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <!-- 连接状态指示 -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="16" Padding="12,4" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                     Fill="{Binding ShellVm.IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                            <TextBlock Text="{Binding ShellVm.ConnectionStatus, FallbackValue='未连接'}" 
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value=""/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShellVm.IsConnected}" Value="True">
                                                <Setter Property="Text" Value="{Binding ShellVm.Latency, StringFormat='{}延迟: {0}ms'}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- PLC CPU Run/Stop 状态灯 -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="16" Padding="10,4" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#BDBDBD"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShellVm.PlcCpuStatus}" Value="Run">
                                                <Setter Property="Fill" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ShellVm.PlcCpuStatus}" Value="Stop">
                                                <Setter Property="Fill" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="CPU: --"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShellVm.PlcCpuStatus}" Value="Run">
                                                <Setter Property="Text" Value="CPU: RUN"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ShellVm.PlcCpuStatus}" Value="Stop">
                                                <Setter Property="Text" Value="CPU: STOP"/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Button Content="🔐 管理员" Click="OnAdminClick" Padding="10,5" VerticalAlignment="Center"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ═══ 主内容 TabControl ═══ -->
        <TabControl Grid.Row="1" Background="Transparent" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0"
                    Padding="0">
            <TabItem Header="🔌 连接配置" IsSelected="True">
                <ContentControl Content="{Binding ConnectionView}"/>
            </TabItem>
            <TabItem Header="📊 DB 解析器"
                     Visibility="{Binding ShellVm.IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                <ContentControl Content="{Binding DbParserView}"/>
            </TabItem>
            <TabItem Header="🎛️ 控制面板">
                <ContentControl Content="{Binding ControlPanelView}"/>
            </TabItem>
            <TabItem Header="📁 DB 文件管理"
                     Visibility="{Binding ShellVm.IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                <ContentControl Content="{Binding DbFilesView}"/>
            </TabItem>
            <TabItem Header="📋 配方管理">
                <ContentControl Content="{Binding RecipeView}"/>
            </TabItem>
        </TabControl>

        <!-- ═══ 底部状态栏 ═══ -->
        <Border Grid.Row="2" Background="{StaticResource CardBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="就绪" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center"
                           Text="{Binding Source={x:Static System:DateTime.Now}, StringFormat='{}v1.0 | {0:yyyy-MM-dd}'}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
